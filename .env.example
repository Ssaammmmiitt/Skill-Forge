# Backend Configuration
FLASK_ENV=development
DEBUG=True
PORT=5001

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
SECRET_KEY=flask-dev-secret-key-2026

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Groq AI (document reader) — supports multiple keys for rate limits
GROQ_API_KEY=your-groq-api-key
# GROQ_API_KEY2=your-second-groq-api-key
# GROQ_API_KEYS=key1,key2
GROQ_MODEL=llama-3.3-70b-versatile

# Document compression — only runs when upload exceeds 12 MB (optional overrides)
# COMPRESS_THRESHOLD_BYTES=12582912
# MAX_RAW_UPLOAD_BYTES=26214400
# MAX_COMPRESSED_BYTES=12582912
